# =============================================================================
# Socketify .gitignore
# =============================================================================

# --- Build / CMake -----------------------------------------------------------
/build*/
/out/
/cmake-build-*/
/CMakeFiles/
/CMakeCache.txt
/cmake_install.cmake
/compile_commands.json
/CTestTestfile.cmake
/Makefile
/Testing/
/_CPack_Packages/
/CPackConfig.cmake
/CPackSourceConfig.cmake
*.cmake
!cmake/*.cmake
!packaging/*.cmake.in

# --- Compiled artifacts ------------------------------------------------------
*.o
*.obj
*.so
*.so.*
*.a
*.la
*.lo
*.dll
*.dylib
*.exe
*.out
*.app
*.d
*.gch
*.pch
*.mod
*.smod

# --- Local dependency sysroot / vendored debs --------------------------------
/.deps/
*.deb

# --- Generated documentation (LOCAL ONLY — never commit / never push) --------
# Produced by ./scripts/serve_docs.sh  →  docs/generated/
/docs/generated/
docs/generated/
**/docs/generated/**
/html/
/latex/
/man/
/xml/
/rtf/

# --- Install / packaging stage dirs ------------------------------------------
/install/
/local/
/prefix/
/dist/
/package/

# --- Examples / tests build debris -------------------------------------------
/examples/*/CMakeFiles/
/examples/*/cmake_install.cmake
/examples/*/Makefile
/examples/*/*.o
/examples/*/*.exe
/examples/*/*.out
/examples/06_https/server.crt
/examples/06_https/server.key
/tests/*/CMakeFiles/
/tests/*/cmake_install.cmake
/tests/*/Makefile
/tests/*/*.o
/tests/*/*.exe
/tests/*/*.out

# --- IDE / editor ------------------------------------------------------------
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*.swn
*.swm
*~
*.sublime-project
*.sublime-workspace
.clangd/
.cache/
.ccls-cache/
compile_flags.txt

# --- OS junk -----------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Logs / temp / secrets ---------------------------------------------------
*.log
*.tmp
*.bak
*.orig
*.rej
.env
.env.*
!.env.example
*.pem
*.key
!examples/06_https/gen_cert.sh
secrets/
credentials.json

# --- Coverage / sanitizers / profiling ---------------------------------------
*.gcda
*.gcno
*.gcov
coverage/
*.profraw
*.profdata
asan.log.*
tsan.log.*
ubsan.log.*

# --- Python tooling (pip-installed cmake helpers, venv) ----------------------
.venv/
venv/
__pycache__/
*.pyc
