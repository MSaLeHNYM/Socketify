@PACKAGE_INIT@

# SocketifyConfig.cmake — find_package(Socketify) entry point.

include(CMakeFindDependencyMacro)

find_dependency(nlohmann_json 3.11)
find_dependency(ZLIB)
find_dependency(Threads)
if(@SOCKETIFY_WITH_TLS@)
    find_dependency(OpenSSL)
endif()
if(@SOCKETIFY_HAS_SQLITE_INT@)
    if(NOT @SOCKETIFY_SQLITE_VENDORED@)
        find_dependency(SQLite3)
    endif()
endif()
if(@SOCKETIFY_HAS_POSTGRES_INT@)
    find_dependency(PostgreSQL)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/SocketifyTargets.cmake")

check_required_components(Socketify)
